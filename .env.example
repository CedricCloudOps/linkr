# Copy to .env for local runs. All variables are prefixed with LINKR_.
LINKR_ENV=development
LINKR_DATABASE_URL=postgresql+psycopg://linkr:linkr@localhost:5432/linkr
LINKR_REDIS_URL=redis://localhost:6379/0
LINKR_BASE_URL=http://localhost:8000
LINKR_LOG_LEVEL=INFO
LINKR_CACHE_TTL_SECONDS=3600
LINKR_SHORTCODE_LENGTH=7
